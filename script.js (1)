// ================= REGISTER FUNCTION =================
// Used on register page to create new user
function register() {
    let email = document.getElementById("regEmail").value.trim().toLowerCase();
    let pass = document.getElementById("regPass").value;

    // Check empty fields
    if(email === "" || pass === "") {
        alert("Please fill all fields");
        return;
    }

    // Check if already registered
    if(localStorage.getItem(email)) {
        alert("Email already exists");
        return;
    }

    // Save email & password in localStorage
    localStorage.setItem(email, pass);

    alert("Registered Successfully");
    window.location.href = "index.html"; // go to login page
}


// ================= LOGIN FUNCTION =================
// Used to login user
function login() {
    let email = document.getElementById("loginEmail").value.trim().toLowerCase();
    let pass = document.getElementById("loginPass").value;

    let savedPass = localStorage.getItem(email);

    // Check login
    if(savedPass === pass) {
        localStorage.setItem("currentUser", email); // save current user
        window.location.href = "dashboard.html";
    } else {
        alert("Invalid Login");
    }
}


// ================= LOGOUT =================
// Remove user session
function logout() {
    localStorage.removeItem("currentUser");
    window.location.href = "index.html";
}


