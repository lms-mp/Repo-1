// ================= DATA FUNCTIONS =================

// Get books from localStorage
function getBooks() {
    return JSON.parse(localStorage.getItem("books")) || [];
}

// Get issued books
function getIssued() {
    return JSON.parse(localStorage.getItem("issued")) || [];
}

// Save books
function saveBooks(data) {
    localStorage.setItem("books", JSON.stringify(data));
}

// Save issued books
function saveIssued(data) {
    localStorage.setItem("issued", JSON.stringify(data));
}


// ================= ADMIN FUNCTIONS =================
// ONLY for admin.html page

function addBook() {
    // Get book name
    let name = document.getElementById("bookName").value;

    if (name === "") return alert("Enter book name");

    let books = getBooks();

    // Add new book (string format)
    books.push(name);

    saveBooks(books);

    alert("Book Added");
}

function deleteBook() {
    let name = document.getElementById("deleteBook").value;

    let books = getBooks();

    // Remove book
    books = books.filter(b => b !== name);

    saveBooks(books);

    alert("Book Deleted");
}


// ================= DASHBOARD FUNCTIONS =================
// ONLY for dashboard.html page

function loadBooks() {
    let books = getBooks();
    let list = document.getElementById("bookList");

    if (!list) return;

    list.innerHTML = "";

    books.forEach((book, i) => {
        let li = document.createElement("li");

        li.innerHTML = `
            ${book}
            <button onclick="issueBook(${i})">Issue</button>
        `;

        list.appendChild(li);
    });
}

function loadIssued() {
    let issued = getIssued();
    let list = document.getElementById("issuedList");

    if (!list) return;

    list.innerHTML = "";

    issued.forEach((book, i) => {
        let li = document.createElement("li");

        li.innerHTML = `
            ${book}
            <button onclick="returnBook(${i})">Return</button>
        `;

        list.appendChild(li);
    });
}


// ================= ISSUE BOOK =================
function issueBook(i) {
    let books = getBooks();
    let issued = getIssued();

    // Remove from books
    let book = books.splice(i, 1)[0];

    // Add to issued
    issued.push(book);

    saveBooks(books);
    saveIssued(issued);

    loadBooks();
    loadIssued();
}


// ================= RETURN BOOK =================
function returnBook(i) {
    let books = getBooks();
    let issued = getIssued();

    let book = issued.splice(i, 1)[0];

    books.push(book);

    saveBooks(books);
    saveIssued(issued);

    loadBooks();
    loadIssued();
}


